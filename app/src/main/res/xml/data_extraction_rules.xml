<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="com.google.firebase.auth.api.crypto.xml" />
        <!-- Keystore-encrypted; undecryptable after restore (see backup_rules.xml). -->
        <exclude domain="sharedpref" path="studymate_session.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="com.google.firebase.auth.api.crypto.xml" />
        <exclude domain="sharedpref" path="studymate_session.xml" />
    </device-transfer>
</data-extraction-rules>

<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.StudyMateAI" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Shown while the app process starts; core-splashscreen backports the
         Android 12 system splash to older API levels so every device behaves the same. -->
    <style name="Theme.StudyMateAI.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <!-- Vector logo: renders crisp at any size, unlike the old raster mipmaps. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground_vector</item>
        <item name="postSplashScreenTheme">@style/Theme.StudyMateAI</item>
    </style>
</resources>